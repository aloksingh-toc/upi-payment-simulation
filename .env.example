# Copy this file to .env and fill in real values before running docker-compose.
# Never commit .env to version control.

APP_API_KEY=replace-with-a-secure-random-string
WEBHOOK_SECRET=replace-with-a-secure-random-string

POSTGRES_PASSWORD=replace-with-a-secure-password
POSTGRES_USER=upi_user
POSTGRES_DB=upi_payment

# Password exposed to the Spring datasource (must match POSTGRES_PASSWORD above)
DB_PASSWORD=replace-with-a-secure-password

# Set to true to enable Swagger UI at /swagger-ui.html (disable in production)
SWAGGER_ENABLED=false
